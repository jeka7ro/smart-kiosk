# Smart Kiosk — Environment Configuration
# Copy this to .env and fill in values

# ─── Server ───────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── PostgreSQL ───────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/smart_kiosk

# ─── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Syrve (iiko) Cloud API ────────────────
SYRVE_API_URL=https://api-eu.syrve.live

# SmashMe
SYRVE_API_KEY=your_smashme_syrve_api_key
SYRVE_ORG_IDS=your_smashme_org_id

# SushiMaster / WeLoveSushi / Ikura (same API key, different orgs)
SYRVE_API_KEY_SUSHI=your_sushi_syrve_api_key
SYRVE_ORG_ID_SUSHI=your_sushimaster_org_id
SYRVE_ORG_ID_WELOVESUSHI=your_welovesushi_org_id
SYRVE_ORG_ID_IKURA=your_ikura_org_id
# Note: if org IDs above are empty, they will be auto-discovered from Syrve on startup

# ─── Viva.com ─────────────────────────────
VIVA_API_URL=https://api.vivapayments.com
VIVA_SMART_CHECKOUT_URL=https://www.vivapayments.com/web/checkout
VIVA_CLIENT_ID=your_viva_client_id
VIVA_CLIENT_SECRET=your_viva_client_secret
VIVA_MERCHANT_ID=your_viva_merchant_id
VIVA_API_KEY=your_viva_api_key
VIVA_SOURCE_CODE=your_viva_source_code

# ─── Raiffeisen ECR ───────────────────────
# Agent runs locally on each kiosk PC
RAIFFEISEN_ECR_TIMEOUT_MS=30000

# ─── App URLs ─────────────────────────────
KIOSK_URL=http://localhost:3000
QR_WEB_URL=http://localhost:3003
ADMIN_URL=http://localhost:3001
KITCHEN_URL=http://localhost:3002

# ─── Menu Sync ────────────────────────────
MENU_SYNC_INTERVAL_MINUTES=15
STOPLIST_SYNC_INTERVAL_SECONDS=120
